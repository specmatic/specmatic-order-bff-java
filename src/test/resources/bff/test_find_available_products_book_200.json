{
  "before": [
    {
      "type": "http",
      "http-request": {
        "baseUrl": "http://localhost:9999",
        "path": "/_specmatic/snapshot",
        "method": "POST"
      },
      "http-response": {
        "status": 200
      },
      "timeout": "PT5S"
    }
  ],
  "http-request": {
    "path": "/findAvailableProducts?type=book",
    "method": "GET",
    "headers": {
      "pageSize": "10"
    },
    "query": {
      "from-date": "2025-10-01",
      "to-date": "2025-10-15"
    }
  },
  "http-response": {
    "status": 200,
    "body": [],
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "after": [
    {
      "type": "http",
